# Slack credentials (required)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Claude Code CLI path (optional, defaults to "claude")
CLAUDE_CLI_PATH=claude

# Working directory for Claude Code sessions (the repo it operates on)
CLAUDE_WORK_DIR=/home/you/projects/your-target-repo

# Base arguments passed to the Claude Code CLI
CLAUDE_CLI_ARGS=-p --output-format json 

# Extra arguments passed to the Claude Code CLI (optional, space-separated)
# Example: CLAUDE_EXTRA_ARGS=--model sonnet --verbose
CLAUDE_EXTRA_ARGS=
